" Vim-plug plugin manager
call plug#begin('~/.vim/plugged')
Plug 'udalov/kotlin-vim'
Plug 'catppuccin/vim', { 'as': 'catppuccin' }
call plug#end()

" Enable syntax highlighting
syntax on

" Set Catppuccin Mocha colorscheme
colorscheme catppuccin_mocha

" Enable file type detection, plugins, and indentation
filetype plugin indent on

" Show line numbers
set nu

" Customize line number appearance (dark grey color)
highlight LineNr term=bold cterm=NONE ctermfg=DarkGrey ctermbg=NONE gui=NONE guifg=DarkGrey guibg=NONE

" Set tab settings: 4 spaces per tab, use spaces instead of tabs
set tabstop=4 shiftwidth=4 expandtab

" Automatically indent new lines to match previous line
set autoindent

" Enable smart indentation for programming languages
set smartindent

" Kotlin-specific indentation settings
autocmd FileType kotlin setlocal shiftwidth=4 tabstop=4 expandtab
autocmd FileType kotlin setlocal cindent
autocmd FileType kotlin setlocal cinkeys-=0#
autocmd FileType kotlin setlocal indentkeys-=0#

" Show invisible characters: $ for line endings, >- for tabs, ~ for trailing spaces
:set listchars=eol:$,tab:>-,trail:~,extends:>,precedes:<

" Custom key mappings: shift home row (j→h, k→j, l→k, ;→l)
nnoremap j h
nnoremap k j
nnoremap l k
nnoremap ; l

vnoremap j h
vnoremap k j
vnoremap l k
vnoremap ; l

" Visual mode mapping: '//' searches for the currently selected text
vnoremap // y/<C-R>"<CR>